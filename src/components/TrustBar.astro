---
import { Image } from 'astro:assets';
import proautoLogo from '@/assets/images/proauto.png';
---

<section class="py-5 bg-primary" aria-label="Parceiros">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-center gap-3">
      <span class="text-white/50 text-xs font-medium uppercase tracking-wider">Trabalhamos com</span>
      <Image
        src={proautoLogo}
        alt="ProAuto - Parceira Nardini Seguros"
        class="h-9 md:h-10 w-auto"
        loading="lazy"
      />
    </div>
  </div>
</section>
