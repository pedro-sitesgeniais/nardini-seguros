---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import heroBg from '@/assets/images/hero-bg.png';
import CotacaoForm from './CotacaoForm.tsx';

---

<section class="relative overflow-hidden text-white min-h-screen md:min-h-[640px] flex items-center">
  <!-- Background image -->
  <div class="absolute inset-0">
    <Image
      src={heroBg}
      alt="Família protegida com seguro e proteção veicular Nardini Seguros em Americana SP"
      class="w-full h-full object-cover"
      loading="eager"
      width={1920}
      height={1080}
    />
    <!-- Gradient mesh overlay (animated) -->
    <div
      class="absolute inset-0 animate-gradient-shift"
      style="background: linear-gradient(135deg, hsl(242 45% 15% / 0.85) 0%, hsl(242 45% 22% / 0.75) 35%, hsl(220 50% 18% / 0.80) 65%, hsl(242 45% 12% / 0.90) 100%); background-size: 200% 200%;"
    ></div>
  </div>

  <div class="container mx-auto px-4 py-16 md:py-24 relative z-10">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center max-w-6xl mx-auto">
      <!-- Left: copy -->
      <div class="text-center lg:text-left">
        <!-- Glass badge -->
        <div class="inline-flex items-center gap-2 glass rounded-full px-4 py-2 mb-6 animate-fade-up">
          <Icon name="lucide:zap" class="h-4 w-4 text-secondary" />
          <span class="text-sm font-medium text-white/90">Resposta rápida pelo formulário</span>
        </div>

        <!-- Icon trio with gradient backgrounds -->
        <div class="flex justify-center lg:justify-start gap-4 mb-6 animate-fade-up animation-delay-100">
          <div class="flex items-center justify-center w-12 h-12 rounded-2xl bg-secondary/20 shadow-md">
            <Icon name="lucide:shield-check" class="h-6 w-6 text-secondary" />
          </div>
          <div class="flex items-center justify-center w-12 h-12 rounded-2xl bg-white/10 shadow-md">
            <Icon name="lucide:car" class="h-6 w-6 text-white/80" />
          </div>
          <div class="flex items-center justify-center w-12 h-12 rounded-2xl bg-white/10 shadow-md">
            <Icon name="lucide:map-pin" class="h-6 w-6 text-white/70" />
          </div>
        </div>

        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold mb-5 animate-fade-up animation-delay-200 leading-[1.05] tracking-tight">
          Confiança que te <span class="text-secondary">Protege!</span>
        </h1>

        <p class="text-base md:text-lg text-white/80 mb-6 animate-fade-up animation-delay-300 max-w-xl lg:max-w-none mx-auto lg:mx-0 leading-relaxed">
          Seguros, Proteção Veicular e Rastreamento em Americana/SP. Atendimento 24h humanizado para você e sua família.
        </p>

        <p class="text-sm text-white/50 mb-4 animate-fade-up animation-delay-400">
          Cotação gratuita &bull; Sem compromisso &bull; Atendimento humanizado
        </p>

        <!-- Selo parceria ProAuto -->
        <div class="inline-flex items-center gap-2 glass rounded-full px-5 py-2.5 animate-fade-up animation-delay-500">
          <Icon name="lucide:badge-check" class="h-4 w-4 text-secondary" />
          <span class="text-sm font-semibold text-white/90">Parceira autorizada ProAuto</span>
        </div>
      </div>

      <!-- Right: form -->
      <div class="animate-fade-up animation-delay-300 w-full max-w-md mx-auto lg:max-w-none">
        <CotacaoForm client:load variant="hero" />
      </div>
    </div>
  </div>
</section>
